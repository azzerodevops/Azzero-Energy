# ============================================
# AzzeroCO2 Energy - Environment Variables
# ============================================
# Copy this file to .env and fill in your values
# ============================================

# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret

# Database (Supabase PostgreSQL direct connection)
# Use your Supabase database password (set during project creation), NOT the JWT secret.
# Transaction pooler (port 6543) for serverless, Session pooler (port 5432) for migrations.
DATABASE_URL=postgresql://postgres.[project-ref]:[YOUR-DB-PASSWORD]@aws-0-eu-central-1.pooler.supabase.com:6543/postgres
